# RPC and data sources (only needed for live position reads, not for the offline engine/tests)
HELIUS_API_KEY=
BIRDEYE_API_KEY=

# Default wallet to analyze when none is given
WALLET_ADDRESS=

# Ledger location (snapshots are appended here). Defaults to ./.lp-desk
LP_DESK_HOME=

# Rebalance decision inputs
# Capital-gains rate applied to realized gains when estimating tax drag (0 disables tax drag)
TAX_RATE_BPS=0
# Cost-basis method: fifo | hifo | specid
TAX_METHOD=fifo

# Execution caps (USD). Required before any plan can be handed off for signing.
MAX_SLIPPAGE_BPS=50
MAX_NOTIONAL_USD=
MAX_POSITION_USD=
MAX_DAILY_LOSS_USD=

# Safety switches
DRY_RUN=true
REQUIRE_CONFIRM=true
KILL_SWITCH=false
